<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/study_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/backInput"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="← 입력"
                android:textColor="@color/study_text_muted"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:text="✓ 저장 완료"
                android:textColor="@color/study_success"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="데이터베이스 기본키 정리"
            android:textColor="@color/study_text"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="과목: 데이터베이스"
            android:textColor="@color/study_text_muted"
            android:textSize="17sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="AI 요약"
            android:textColor="@color/study_text_muted"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_summary_box"
            android:padding="@dimen/card_padding"
            android:text="기본키는 각 행을 고유하게 식별하는 속성이다.\n중복 및 NULL 값을 허용하지 않는다.\n테이블당 하나만 존재하며 개체 무결성을 유지한다."
            android:textColor="@color/study_text"
            android:textSize="18sp"
            android:lineSpacingExtra="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="핵심 키워드"
            android:textColor="@color/study_text_muted"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip"
                android:text="# 기본키"
                android:textColor="@color/study_text"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip"
                android:text="# 개체무결성"
                android:textColor="@color/study_text"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip"
                android:text="# NULL불허"
                android:textColor="@color/study_text"
                android:textSize="16sp" />
        </LinearLayout>

        <Button
            android:id="@+id/createQuizButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_button_primary"
            android:text="퀴즈 생성하기"
            android:textAllCaps="false"
            android:textColor="@color/study_primary_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="AI가 생성한 요약과 퀴즈는 학습 보조 자료입니다. 중요한 내용은 사용자가 한 번 더 확인해주세요."
            android:textColor="@color/study_text_muted"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
