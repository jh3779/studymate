<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/study_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingTop="@dimen/screen_top_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingBottom="@dimen/screen_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/backInput"
                style="@style/StudyMateBackNavigation"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="입력" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:text="✓ 저장 완료"
                android:textColor="@color/study_success"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/summaryTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/study_text"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/summarySubject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="@color/study_text_muted"
            android:textSize="17sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="AI 요약"
            android:textColor="@color/study_text_muted"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/summaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_summary_box"
            android:lineSpacingExtra="6dp"
            android:padding="@dimen/card_padding"
            android:textColor="@color/study_text"
            android:textSize="18sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="핵심 키워드"
            android:textColor="@color/study_text_muted"
            android:textSize="17sp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/keywordsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/quizLoadingBox"
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card"
            android:gravity="center"
            android:text="⏳ AI 퀴즈 생성 중...\n잠시만 기다려주세요"
            android:textColor="@color/study_text_muted"
            android:textSize="16sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/createQuizButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_button_primary"
            android:text="퀴즈 생성하기"
            android:textAllCaps="false"
            android:textColor="@color/study_primary_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="AI가 생성한 요약과 퀴즈는 학습 보조 자료입니다. 중요한 내용은 사용자가 한 번 더 확인해주세요."
            android:textColor="@color/study_text_muted"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
