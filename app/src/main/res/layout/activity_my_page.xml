<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/study_bg"
    android:orientation="vertical"
    tools:context=".MyPageActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingTop="@dimen/screen_top_padding"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingBottom="@dimen/screen_padding">

            <TextView
                style="@style/StudyMateHeaderEyebrow"
                android:text="내 학습 정보" />

            <TextView
                style="@style/StudyMatePageTitle"
                android:layout_marginTop="@dimen/header_title_gap"
                android:text="마이페이지" />

            <TextView
                android:id="@+id/accountText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/page_content_gap"
                android:text="로그인 사용자\n회원"
                android:textColor="@color/study_text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <TextView
                    android:id="@+id/myStudyCountText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="92dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:text="0\n학습 기록"
                    android:textColor="@color/study_text"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/myQuizCountText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="92dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:text="0\n퀴즈 풀이"
                    android:textColor="@color/study_text"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/myAverageScoreText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:minHeight="72dp"
                android:background="@drawable/bg_card"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="0%\n평균 정답률"
                android:textColor="@color/study_success"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="앱 버전"
                        android:textColor="@color/study_text_muted"
                        android:textSize="17sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.0.0 (MVP)"
                        android:textColor="@color/study_text_muted"
                        android:textSize="17sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="이용 약관"
                        android:textColor="@color/study_text_muted"
                        android:textSize="17sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="@color/study_text_muted"
                        android:textSize="20sp" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/logoutButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/button_height"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_button_danger"
                app:backgroundTint="@null"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="로그아웃"
                android:textAllCaps="false"
                android:textColor="@color/study_error"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="72dp"
        android:background="@color/study_surface"
        android:gravity="center"
        android:orientation="horizontal"
        android:weightSum="3">

        <TextView
            android:id="@+id/myHomeTab"
            style="@style/StudyMateBottomTab"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="홈" />

        <TextView
            android:id="@+id/myWrongTab"
            style="@style/StudyMateBottomTab"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="오답노트" />

        <TextView
            android:id="@+id/myCurrentTab"
            style="@style/StudyMateBottomTabSelected"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="마이페이지" />
    </LinearLayout>
</LinearLayout>
