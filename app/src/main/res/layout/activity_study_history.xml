<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/study_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingTop="@dimen/screen_top_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingBottom="@dimen/screen_padding">

        <TextView
            android:id="@+id/studyHistoryBack"
            style="@style/StudyMateBackNavigation"
            android:text="홈" />

        <TextView
            style="@style/StudyMatePageTitle"
            android:layout_marginTop="@dimen/header_title_gap"
            android:text="전체 학습 기록" />

        <TextView
            android:id="@+id/historyStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_content_gap"
            android:text="학습 기록을 불러오는 중입니다."
            android:textColor="@color/study_text_muted"
            android:textSize="15sp" />

        <LinearLayout
            android:id="@+id/studyHistoryContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
