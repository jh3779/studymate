<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingTop="@dimen/screen_top_padding"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingBottom="@dimen/screen_padding">

            <TextView
                android:id="@+id/backResult"
                style="@style/StudyMateBackNavigation"
                android:text="@string/wrong_answer_back_result"
                android:contentDescription="@string/cd_back_result" />

            <TextView
                android:id="@+id/wrongAnswerEyebrow"
                style="@style/StudyMateHeaderEyebrow"
                android:text="복습이 필요한 문제"
                android:visibility="gone" />

            <TextView
                android:id="@+id/wrongAnswerTitle"
                style="@style/StudyMatePageTitle"
                android:layout_marginTop="@dimen/header_title_gap"
                android:text="오답노트" />

            <!-- 학습 노트 선택 패널: 바텀 탭에서 진입 시 표시 -->
            <LinearLayout
                android:id="@+id/noteSelectPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/page_content_gap"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="오답이 있는 학습 기록"
                    android:textColor="@color/study_text_muted"
                    android:textSize="17sp" />

                <LinearLayout
                    android:id="@+id/noteSelectContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- 오답 상세 패널: 퀴즈 결과 진입 시 또는 노트 선택 후 표시 -->
            <LinearLayout
                android:id="@+id/wrongAnswerDetailPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/quizProgressText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="오답 진행 상황"
                    android:textColor="@color/study_text_muted"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/questionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_card"
                    android:padding="@dimen/card_padding"
                    android:text="Q. 질문 내용이 로딩 중입니다."
                    android:textColor="@color/study_text"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/optionOne"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card"
                    android:padding="@dimen/card_padding"
                    android:text="내 답: 데이터 로딩 중"
                    android:textColor="@color/study_error"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/optionTwo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card"
                    android:padding="@dimen/card_padding"
                    android:text="정답: 데이터 로딩 중"
                    android:textColor="@color/study_success"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/optionThree"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card"
                    android:padding="@dimen/card_padding"
                    android:text="해설: 데이터 로딩 중"
                    android:textColor="@color/study_text_muted"
                    android:textSize="15sp"
                    android:lineSpacingExtra="6dp" />

                <Button
                    android:id="@+id/retryWrongButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_button_primary"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:text="이 문제 다시 풀기"
                    android:textAllCaps="false"
                    android:textColor="@color/study_primary_text"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/retryQuizButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_secondary"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:text="다음 오답 보기"
                    android:textAllCaps="false"
                    android:textColor="@color/study_text"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="72dp"
        android:background="@color/study_surface"
        android:gravity="center"
        android:orientation="horizontal"
        android:weightSum="3">

        <TextView
            android:id="@+id/wrongHomeTab"
            style="@style/StudyMateBottomTab"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="홈"
            android:contentDescription="@string/cd_tab_home" />

        <TextView
            android:id="@+id/wrongCurrentTab"
            style="@style/StudyMateBottomTabSelected"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="오답노트"
            android:contentDescription="@string/cd_tab_wrong" />

        <TextView
            android:id="@+id/wrongMyPageTab"
            style="@style/StudyMateBottomTab"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="마이페이지"
            android:contentDescription="@string/cd_tab_mypage" />
    </LinearLayout>
</LinearLayout>
