<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingTop="@dimen/screen_top_padding"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingBottom="@dimen/screen_padding">

            <TextView
                style="@style/StudyMateHeaderEyebrow"
                android:text="안녕하세요 👋" />

            <TextView
                style="@style/StudyMatePageTitle"
                android:layout_marginTop="@dimen/header_title_gap"
                android:text="오늘도 학습해볼까요?" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/page_content_gap"
                android:orientation="horizontal"
                android:weightSum="3">

                <TextView
                    android:id="@+id/totalStudyStatText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="104dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:text="0\n총 학습"
                    android:contentDescription="@string/cd_stat_study"
                    android:textColor="@color/study_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/quizCountStatText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="104dp"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:text="0\n퀴즈 풀이"
                    android:contentDescription="@string/cd_stat_quiz"
                    android:textColor="@color/study_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/averageScoreStatText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="104dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:text="0%\n평균 정답률"
                    android:contentDescription="@string/cd_stat_avg"
                    android:textColor="@color/study_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/homeStatsStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:textColor="@color/study_text_muted"
                android:textSize="14sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/startStudyButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/button_height"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_button_primary"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="+ 오늘의 학습 시작"
                android:textAllCaps="false"
                android:textColor="@color/study_primary_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/recentNotesTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="최근 학습 기록"
                android:textColor="@color/study_text_muted"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/emptyRecentNotesText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card"
                android:padding="@dimen/card_padding"
                android:text="최근 학습 기록을 불러오는 중입니다."
                android:textColor="@color/study_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/recentNotesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="72dp"
        android:background="@color/study_surface"
        android:gravity="center"
        android:orientation="horizontal"
        android:weightSum="3">

        <TextView
            android:id="@+id/homeTab"
            style="@style/StudyMateBottomTabSelected"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="홈"
            android:contentDescription="@string/cd_tab_home" />

        <TextView
            android:id="@+id/wrongTab"
            style="@style/StudyMateBottomTab"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="오답노트"
            android:contentDescription="@string/cd_tab_wrong" />

        <TextView
            android:id="@+id/myPageTab"
            style="@style/StudyMateBottomTab"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="마이페이지"
            android:contentDescription="@string/cd_tab_mypage" />
    </LinearLayout>
</LinearLayout>
