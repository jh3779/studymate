<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <TextView
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:background="@drawable/bg_logo"
        android:contentDescription="StudyMate 앱 로고"
        android:gravity="center"
        android:text="S"
        android:textColor="@color/study_primary_text"
        android:textSize="36sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="StudyMate"
        android:textColor="@color/study_text"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="AI 학습 요약 · 퀴즈"
        android:textColor="@color/study_text_muted"
        android:textSize="18sp" />

    <ProgressBar
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="160dp"
        android:layout_height="8dp"
        android:layout_marginTop="36dp"
        android:indeterminate="true"
        android:contentDescription="로그인 상태 확인 진행 중" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="로그인 상태 확인 중..."
        android:textColor="@color/study_text_muted"
        android:textSize="16sp" />
</LinearLayout>
