<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/study_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingTop="@dimen/screen_top_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingBottom="@dimen/screen_padding">

        <TextView
            android:id="@+id/backToLoginFromVerification"
            style="@style/StudyMateBackNavigation"
            android:text="로그인" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="이메일 인증"
            android:textColor="@color/study_text"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/verificationEmailText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card"
            android:padding="@dimen/card_padding"
            android:textColor="@color/study_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="메일에서 인증 링크를 누른 뒤 아래 버튼을 눌러주세요."
            android:textColor="@color/study_text_muted"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/verificationErrorText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/study_error"
            android:textSize="15sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/verifyEmailButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_primary"
            android:text="인증 완료 확인"
            android:textAllCaps="false"
            android:textColor="@color/study_primary_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/resendVerificationButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_secondary"
            android:text="인증 메일 재전송"
            android:textAllCaps="false"
            android:textColor="@color/study_text"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
