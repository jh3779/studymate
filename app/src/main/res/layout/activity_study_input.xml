<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/study_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingTop="@dimen/screen_top_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingBottom="@dimen/screen_padding">

        <TextView
            android:id="@+id/backHome"
            style="@style/StudyMateBackNavigation"
            android:text="홈"
            android:contentDescription="@string/cd_back_home" />

        <TextView
            style="@style/StudyMatePageTitle"
            android:layout_marginTop="@dimen/header_title_gap"
            android:text="학습 내용 입력" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/page_content_gap"
            android:text="제목 *"
            android:labelFor="@id/titleInput"
            android:importantForAccessibility="no"
            android:textColor="@color/study_text_muted"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/titleInput"
            android:layout_width="match_parent"
            android:layout_height="@dimen/field_height"
            android:layout_marginTop="8dp"
            android:importantForAutofill="no"
            android:background="@drawable/bg_input"
            android:hint="학습 제목을 입력해주세요."
            android:inputType="text"
            android:textColor="@color/study_text"
            android:textColorHint="@color/study_text_muted" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="과목명"
            android:labelFor="@id/subjectInput"
            android:importantForAccessibility="no"
            android:textColor="@color/study_text_muted"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/subjectInput"
            android:layout_width="match_parent"
            android:layout_height="@dimen/field_height"
            android:layout_marginTop="8dp"
            android:importantForAutofill="no"
            android:background="@drawable/bg_input"
            android:hint="과목명을 입력해주세요."
            android:inputType="text"
            android:textColor="@color/study_text"
            android:textColorHint="@color/study_text_muted" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="학습 내용 *"
            android:labelFor="@id/contentInput"
            android:importantForAccessibility="no"
            android:textColor="@color/study_text_muted"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/contentInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="132dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input"
            android:gravity="top"
            android:hint="학습 내용을 30자 이상 입력해주세요."
            android:importantForAutofill="no"
            android:inputType="textMultiLine"
            android:paddingTop="14dp"
            android:textColor="@color/study_text"
            android:textColorHint="@color/study_text_muted" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/importPdfButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="PDF 가져오기"
                android:textAllCaps="false"
                android:textColor="@color/study_text"
                android:textSize="15sp" />

            <Button
                android:id="@+id/importImageButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="이미지 OCR"
                android:textAllCaps="false"
                android:textColor="@color/study_text"
                android:textSize="15sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/importStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/study_text_muted"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/inputErrorText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textColor="@color/study_error"
            android:textSize="15sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/loadingBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="92dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card"
            android:gravity="center"
            android:padding="@dimen/card_padding"
            android:text="⏳ AI 요약 생성 중...\n잠시만 기다려주세요"
            android:textColor="@color/study_text_muted"
            android:textSize="16sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/generateSummaryButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button_primary"
            android:text="AI 요약 생성"
            android:textAllCaps="false"
            android:textColor="@color/study_primary_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="개인정보나 민감한 정보는 학습 내용에 입력하지 않는 것을 권장합니다."
            android:textColor="@color/study_text_muted"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
